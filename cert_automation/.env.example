# --- IONOS API Credentials ---
IONOS_API_KEY="your_ionos_api_key_here"
IONOS_API_SECRET="your_ionos_api_secret_here"

# --- ACME Client Settings ---
ACME_EMAIL="your_email@example.com"
ACME_SH_COMMAND="/path/to/acme.sh" # e.g., /home/certuser/.acme.sh/acme.sh

# --- SSH Deployment Credentials ---
# Used in servers.yaml via ${SSH_USER} and ${SSH_KEY_PATH} placeholders
SSH_USER="automation_user"          # Linux user on the target servers
SSH_KEY_PATH="/path/to/ssh/id_rsa"  # Local path to the private key

# --- OTC OpenStack Credentials (for ELB Automation) ---
OS_AUTH_URL="https://iam.eu-de.otc.t-systems.com/v3"
OS_USER_DOMAIN_NAME="OTC-11010000001555"
OS_PROJECT_ID="a7080a390c9a4f74a5f52df0add9f1d2"
OS_USERNAME="cc_cli_user"
OS_PASSWORD="your_otc_password_here"

# --- General System Settings ---
RENEWAL_THRESHOLD_DAYS="40"
CERT_BASE_PATH="/tmp/certs"
ACME_HOME_DIR="/tmp/acme_home"

# --- Reporting & Logging ---
# Paths can be absolute or relative to the script directory
REPORT_FILE_PATH="reports/renewal_report.md"
LOG_FILE_PATH="logs/renewal.log"

# --- GitLab CI Specific (Names used in .gitlab-ci.yml) ---
# TARGET_SSH_HOSTS_GITLAB="10.0.0.15 10.0.0.10 10.0.0.9 10.0.0.14 10.0.0.8 10.0.0.13 10.0.0.3 10.0.0.2"
