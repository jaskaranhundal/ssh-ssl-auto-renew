# IONOS API Credentials (S-203)
IONOS_API_KEY="your_ionos_api_key_here"
IONOS_API_SECRET="your_ionos_api_secret_here"

# ACME Client Settings
ACME_EMAIL="your_email@example.com"
ACME_SH_COMMAND="/path/to/acme.sh" # e.g., /home/user/.acme.sh/acme.sh

# Report Settings
# These can be dynamic (timestamped) if not set here.
# Example: reports/renewal_report_20260211_143000.md
REPORT_FILE_PATH=

# Example: logs/renewal_20260211_143000.log
LOG_FILE_PATH=
